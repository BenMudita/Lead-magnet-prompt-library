# Local demo works without provider keys. Set providers to opt into production services.
AUTH_PROVIDER=demo
DATABASE_PROVIDER=demo
PAYMENTS_PROVIDER=demo
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database/auth, if using Supabase
NEXT_PUBLIC_SUPABASE_URL=
# New Supabase projects use publishable/secret keys. Legacy anon/service_role are also supported.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_FOUNDING_MEMBER_YEARLY=
# Keep false/empty in production unless you intentionally want the local demo upgrade path.
ENABLE_DEMO_CHECKOUT=

# Analytics
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

# Admin-side AI assistance
OPENAI_API_KEY=

# Transactional email
RESEND_API_KEY=

# Twenty CRM lead sync. Leave empty locally; set server-side in Netlify to enable.
TWENTY_SYNC_ENABLED=true
TWENTY_API_BASE_URL=https://api.twenty.com
TWENTY_API_KEY=
TWENTY_PEOPLE_OBJECT=people
# Optional: a Twenty Workflow webhook can receive the full signup payload instead of the direct API.
TWENTY_WEBHOOK_URL=
# Optional: set these to your Twenty custom field API names to write attribution directly to People.
TWENTY_FIELD_SIGNUP_STATUS=
TWENTY_FIELD_SIGNUP_URL=
TWENTY_FIELD_SIGNUP_SOURCE=
TWENTY_FIELD_REFERRER=
TWENTY_FIELD_UTM_SOURCE=
TWENTY_FIELD_UTM_MEDIUM=
TWENTY_FIELD_UTM_CAMPAIGN=
TWENTY_FIELD_PROMPT_SLUG=
TWENTY_FIELD_SUPABASE_USER_ID=
